# ===================================
# AI Friend - Backend Production .env
# ===================================
# Для Railway/Render/Production деплоя

# GROQ API Key
GROQ_API_KEY=your_groq_api_key_here

# База данных (Railway автоматически предоставит)
# DATABASE_URL=postgresql://...

# JWT Token настройки
JWT_SECRET_KEY=change_this_to_secure_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Production URL вашего frontend
FRONTEND_URL=https://ai-friend.vercel.app

# Приложение
APP_NAME=AI Friend
DEBUG=false
