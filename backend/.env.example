# ===================================
# AI Friend - Backend .env
# ===================================

# GROQ API Key - получите на https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# База данных
# Для production (Render/Railway) используйте PostgreSQL!
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Для локальной разработки можно использовать SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./backend/ai_friend.db

# JWT Token настройки
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
FRONTEND_URL=http://localhost:8080

# Приложение
APP_NAME=AI Friend
DEBUG=true

# ===================================
# Stripe (для оплаты подписки)
# ===================================
# Получите ключи на https://dashboard.stripe.com/apikeys

# Secret Key (для бэкенда)
STRIPE_SECRET_KEY=sk_test_...

# Publishable Key (для фронтенда)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook Secret (получите после настройки webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (создайте продукты в Stripe Dashboard)
STRIPE_PRICE_ID_MONTHLY=price_...  # Monthly subscription $9.99
STRIPE_PRICE_ID_YEARLY=price_...   # Yearly subscription $99.99

# ===================================
# Порты
# ===================================
BACKEND_PORT=8000
FRONTEND_PORT=8080
