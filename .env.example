# ===================================
# AI Friend - Переменные окружения
# ===================================
# Скопируйте этот файл в .env и заполните значениями

# ===================================
# Backend (FastAPI)
# ===================================

# GROQ API Key - получите на https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# База данных
# SQLite (для разработки):
DATABASE_URL=sqlite+aiosqlite:///./backend/ai_friend.db
# PostgreSQL (для продакшена):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_friend

# JWT Token настройки
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - разрешённые origin
FRONTEND_URL=http://localhost:8080

# Приложение
APP_NAME=AI Friend
DEBUG=true

# ===================================
# Frontend (Vite/React)
# ===================================
# Переменные для frontend/.env

# URL API (для production сборки)
# VITE_API_URL=http://localhost:8000

# ===================================
# Порты
# ===================================
BACKEND_PORT=8000
FRONTEND_PORT=8080
