# ===================================
# AI Friend - Root .gitignore
# ===================================

# Environment files
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===================================
# Frontend
# ===================================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/

# ===================================
# Backend
# ===================================
backend/__pycache__/
backend/*.py[cod]
backend/venv/
backend/env/
backend/.venv/
backend/*.db
backend/*.sqlite
backend/ai_friend_backend/*.db

# ===================================
# Docker
# ===================================
.docker/
docker-compose.override.yml

# ===================================
# Build artifacts
# ===================================
*.egg-info/
.eggs/
dist/
build/
